#!/usr/bin/env bash
# Orchestra — single-command launcher
# Usage: ./orchestra [--setup]
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WEB_DIR="$SCRIPT_DIR/web"
VENV_PYTHON="$SCRIPT_DIR/.venv/bin/python3"
VENV_PIP="$SCRIPT_DIR/.venv/bin/pip"

# ── Colours ────────────────────────────────────────────────────────────────────
R='\033[0;31m'; G='\033[0;32m'; Y='\033[1;33m'; B='\033[0;34m'; N='\033[0m'
ok()   { echo -e "  ${G}✓${N}  $*"; }
warn() { echo -e "  ${Y}!${N}  $*"; }
err()  { echo -e "  ${R}✗${N}  $*" >&2; }
hdr()  { echo -e "\n${B}$*${N}"; }

# ── --setup mode ───────────────────────────────────────────────────────────────
if [[ "${1:-}" == "--setup" ]]; then
  hdr "Orchestra — first-time setup"

  # .env
  if [ ! -f "$SCRIPT_DIR/.env" ]; then
    cp "$SCRIPT_DIR/.env.example" "$SCRIPT_DIR/.env"
    warn ".env created from .env.example — add your OPENAI_API_KEY"
  else
    ok ".env exists"
  fi

  # Python venv
  if [ ! -f "$VENV_PYTHON" ]; then
    hdr "Creating Python venv..."
    python3 -m venv "$SCRIPT_DIR/.venv"
  else
    ok "Python venv exists"
  fi

  # Python deps
  hdr "Installing Python dependencies..."
  "$VENV_PIP" install -r "$SCRIPT_DIR/requirements.txt"
  ok "Python dependencies installed"

  # Web deps
  hdr "Installing web dependencies..."
  npm install --prefix "$WEB_DIR"
  ok "Web dependencies installed"

  echo -e "\n${G}Setup complete.${N} Run ${B}./orchestra${N} to start Orchestra.\n"
  exit 0
fi

# ── Pre-flight checks ──────────────────────────────────────────────────────────
FAIL=0

# .env / API key
if [ -f "$SCRIPT_DIR/.env" ]; then
  # shellcheck disable=SC1090
  set -o allexport; source "$SCRIPT_DIR/.env"; set +o allexport
fi

if [ -z "${OPENAI_API_KEY:-}" ]; then
  err "OPENAI_API_KEY is not set."
  err "Add it to $SCRIPT_DIR/.env or export it in your shell."
  FAIL=1
fi

# Python venv
if [ ! -f "$VENV_PYTHON" ]; then
  err "Python venv not found. Run:  ./orchestra --setup"
  FAIL=1
fi

# Web node_modules
if [ ! -d "$WEB_DIR/node_modules" ]; then
  err "Web dependencies not installed. Run:  ./orchestra --setup"
  FAIL=1
fi

[ "$FAIL" -eq 1 ] && exit 1

# ── Start API server ───────────────────────────────────────────────────────────
API_PORT="${ORCHESTRA_API_PORT:-7890}"

cd "$SCRIPT_DIR"
"$VENV_PYTHON" -m uvicorn api.main:app \
  --host 127.0.0.1 --port "$API_PORT" \
  --log-level warning &
API_PID=$!

cleanup() {
  kill "$API_PID" 2>/dev/null || true
}
trap cleanup EXIT INT TERM

# Wait for the API to become ready (up to 10 s)
for _ in $(seq 1 20); do
  curl -sf "http://localhost:${API_PORT}/health" > /dev/null 2>&1 && break
  sleep 0.5
done

# ── Launch web dev server ──────────────────────────────────────────────────────
npm run dev --prefix "$WEB_DIR"
